tsd:news_padi_web_oms_casques_de_chantier_ia_et_fausse_grippe_aviaire_ce_quorganisent_en_afrique_ces_anciens_dirigeants_mondiaux_65143_html a ts:NewsReport,
        ts:SourceDocument ;
    ts:referenceId "source_document:padi_web:oms-casques-de-chantier-ia-et-fausse-grippe-aviaire-ce-quorganisent-en-afrique-ces-anciens-dirigeants-mondiaux-65143.html" ;
