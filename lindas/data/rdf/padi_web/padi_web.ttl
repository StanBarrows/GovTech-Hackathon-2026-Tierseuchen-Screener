    ts:sourcePublisher "PADI-web" ;
    ts:sourceRetrievedAt "2026-05-28T19:49:46.095394+00:00"^^xsd:dateTime ;
    ts:sourceURL "https://www.vietnam.vn/fr/dien-bien-khan-truong-trien-khai-cac-bien-phap-phong-chong-cum-gia-cam-a-h5n1"^^xsd:anyURI .

