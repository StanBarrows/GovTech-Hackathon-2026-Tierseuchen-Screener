tsd:report_paff_2026_05_12 a ts:PaffReport ;
  ts:referenceId "reg-com_ahw_20260512_pres-01.pdf" ;
  ts:sourceDocumentTitle "PAFF AHW presentation (example candidate modelling)" ;
  ts:paffDate "2026-05-12"^^xsd:date .

tsd:stmt_asf_germany a ts:PaffSituationStatement ;
