  ts:hasRelevanceAssessment tsd:rel_1 ;
  ts:hasSeverityAssessment tsd:sev_1 ;
  ts:hasReachAssessment tsd:reach_1 ;
  ts:hasPreventionMeasure tsd:pm_1, tsd:pm_2 .

tsd:snip_1 a ts:EvidenceSnippet ;
  ts:sourceSlideNumber 2 ;
