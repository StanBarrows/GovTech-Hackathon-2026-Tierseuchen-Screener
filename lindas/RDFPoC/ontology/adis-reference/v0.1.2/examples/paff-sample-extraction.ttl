tsd:sev_1 a ts:SeverityAssessment ;
  ts:assessesSituation tsd:situation_asf_wild_boar_hu_2026_03 ;
  ts:hasSeverityLevel tss:severity-medium ;
  ts:rawSeverityEvidence "58 positive mentioned in one area" .

tsd:rule_reach_admin_spread a ts:DerivedAssessmentRule ;
  ts:snippetText "same adminLevel3=>local; diff adminLevel3 same adminLevel2=>regional; diff adminLevel2=>national; insufficient=>unknown" .

tsd:reach_1 a ts:ReachAssessment ;
  ts:assessesSituation tsd:situation_asf_wild_boar_hu_2026_03 ;
  ts:hasReachLevel tss:reach-regional ;
  ts:derivedByRule tsd:rule_reach_admin_spread ;
  ts:reachRationale "Candidate level only, derived from distribution statement context." .

tsd:pm_1 a ts:PreventionMeasure ;
  ts:relatesToSituation tsd:situation_asf_wild_boar_hu_2026_03 ;
  ts:preventionMeasureText "intensive surveillance" ;
