# minimal locations with raw admin labels
tsd:loc_witten a ts:Location ; ts:locationLabel "Witten" ; ts:adminLevel1Label "Nordrhein-Westfalen" ; ts:adminLevel2Label "Ennepe-Ruhr-Kreis" ; ts:adminLevel3Label "Witten" .
tsd:loc_heringen a ts:Location ; ts:locationLabel "Heringen (Werra)" ; ts:adminLevel1Label "Hessen" ; ts:adminLevel2Label "Hersfeld-Rotenburg" ; ts:adminLevel3Label "Heringen (Werra)" .
