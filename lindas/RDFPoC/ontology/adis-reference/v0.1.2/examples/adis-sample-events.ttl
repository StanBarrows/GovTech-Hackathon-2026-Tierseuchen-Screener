# Situation keys use confirmation month fallback logic (confirmation > suspicion > submitted > unknown)

tsd:situation_hpai_non_p_wild_birds_de_2026_01 a ts:OutbreakSituation ;
  ts:hasSituationKey "hpai-non-p-wild-birds|de|2026-01" ;
  ts:situationDisease tss:hpai_non_p_wild_birds ;
  ts:situationCountry tsd:country_de ;
  ts:situationMonth "2026-01"^^xsd:gYearMonth .

tsd:situation_hpai_non_p_wild_birds_de_2026_02 a ts:OutbreakSituation ;
  ts:hasSituationKey "hpai-non-p-wild-birds|de|2026-02" ;
  ts:situationDisease tss:hpai_non_p_wild_birds ;
  ts:situationCountry tsd:country_de ;
  ts:situationMonth "2026-02"^^xsd:gYearMonth .

tsd:situation_mtbc_fr_2026_03 a ts:OutbreakSituation ;
  ts:hasSituationKey "mtbc|fr|2026-03" ;
  ts:situationDisease tss:mtbc ;
  ts:situationCountry tsd:country_fr ;
  ts:situationMonth "2026-03"^^xsd:gYearMonth .

tsd:situation_asf_wild_boar_hu_2026_03 a ts:OutbreakSituation ;
